# Cardápio Digital CIICC — exemplo de variáveis de ambiente
# Não inserir segredos reais neste arquivo.

# Identidade do app
VITE_APP_NAME="Cardápio Digital CIICC"
VITE_APP_ENV="local"

# Supabase — configurar nas fases futuras de autenticação/dados
VITE_SUPABASE_URL="https://example.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Observação:
# A Fase 1 não conecta Supabase real, não cria migrations e não altera fluxo funcional.
# Variáveis reais devem ficar apenas em .env.local, Vercel ou ambiente seguro equivalente.
